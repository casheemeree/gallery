# Exactly ten digits. Keep this value only on the server.
ACCESS_CODE=1234567890

# Use a project-specific value. Changing it invalidates future login proofs.
PBKDF2_SALT=change-this-gallery-salt
PBKDF2_ITERATIONS=180000

HOST=127.0.0.1
PORT=8080
SESSION_TTL_SECONDS=86400
MAX_UPLOAD_BYTES=15728640

# Set to 1 behind HTTPS in production.
COOKIE_SECURE=1
