# Generate this verifier and its matching PBKDF2_SALT with:
# python3 server.py generate-access-key
# Never commit either real value or store the original 10-digit code here.
ACCESS_KEY=replace-with-generated-value

# Use the matching value printed by generate-access-key.
PBKDF2_SALT=replace-with-generated-value
PBKDF2_ITERATIONS=180000

HOST=127.0.0.1
PORT=8080
SESSION_TTL_SECONDS=86400
MAX_UPLOAD_BYTES=15728640

# Set to 1 behind HTTPS in production.
COOKIE_SECURE=1
