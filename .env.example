# Access codes are managed with: python3 server.py access-code ...
# Keep this JSON outside Git and readable only by the service account.
ACCESS_CODES_PATH=/srv/capi-gallery/data/access-codes.json
PBKDF2_ITERATIONS=180000

HOST=127.0.0.1
PORT=8080
# 400 days; the server refreshes it when the gallery is opened.
SESSION_TTL_SECONDS=34560000
MAX_UPLOAD_BYTES=15728640

# Set to 1 behind HTTPS in production.
COOKIE_SECURE=1
